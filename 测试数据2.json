data: {"type": "element", "event_type": "element", "content": {"event_type": "element", "element_bid": "09afec1e972d4f03ac07a600743eaf53", "generated_block_bid": "55168e80a01c44439efe4912ed945023", "element_index": 2, "role": "teacher", "element_type": "text", "element_type_code": 213, "is_renderable": false, "is_new": true, "is_marker": false, "sequence_number": 29, "is_speakable": true, "audio_url": "", "audio_segments": [], "is_navigable": 1, "is_final": false, "content": "\n好，这页 PPT 就一个核心观点：**智能体不是新物种，而是大模型穿上了「总监」的西装**。\n", "payload": {"audio": null, "previous_visuals": []}, "run_session_bid": "542f836656a24de9943b0e91f034796b", "run_event_seq": 42, "change_type": "render"}, "generated_block_bid": "55168e80a01c44439efe4912ed945023", "run_session_bid": "542f836656a24de9943b0e91f034796b", "run_event_seq": 42}

